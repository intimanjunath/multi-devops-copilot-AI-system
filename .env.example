# =============================================================================
# SRE SaaS Platform Config
# =============================================================================

# --- Core Security ---
SECRET_KEY="sre_platform_dev_key_change_in_production"

# --- Models ---
LLM_PROVIDER="ollama"
NVIDIA_API_KEY="YOUR_NVIDIA_API_KEY"
# Hosted NVIDIA API (model IDs like minimaxai/minimax-m2.7)
# For local NIM, use: http://localhost:8000/v1 and a local-served model ID.
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"
NVIDIA_MODEL="minimaxai/minimax-m2.7"
GOOGLE_API_KEY="YOUR_KEY"
GEMINI_MODEL="gemini-2.0-flash"
GROQ_API_KEY="YOUR_KEY"
GROQ_MODEL="llama-3.3-70b-versatile"
OLLAMA_BASE_URL="http://host.docker.internal:11434"
OLLAMA_MODEL="gpt-oss:120b-cloud"
OLLAMA_NUM_CTX="32768"

# --- Database ---
POSTGRES_USER="sre_user"
POSTGRES_PASSWORD="sre_password"
POSTGRES_DB="sre_platform"

# --- Edge MCP Tool Links (SaaS -> Edge Bridges) ---
MCP_K8S_URI="http://host.docker.internal:4000/sse"
MCP_METRICS_URI="http://host.docker.internal:4001/sse"
MCP_LOGS_URI="http://host.docker.internal:4002/sse"
MCP_GITHUB_URI="http://host.docker.internal:4003/sse"
MCP_RUNBOOKS_URI="http://host.docker.internal:4004/sse"

# --- Observability Endpoints (For Dashboard Proxy) ---
PROMETHEUS_URL="http://host.docker.internal:9090"
LOKI_URL="http://host.docker.internal:3100"

# --- Directly Connected Target Systems (If not using Edge Relay) ---
K8S_API_SERVER=""
K8S_TOKEN=""

# --- Cluster Auto-Seed ---
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="admin"
SEED_ADMIN_ORG="SRE Admin Org"
SEED_CLUSTER_TOKEN="cl_58f71c23a54e4b5ab1d10c8defccfc6d"
SEED_CLUSTER_NAME="SRE Demo Cluster"
SEED_CLUSTER_STATUS="online"
CLUSTER_TOKEN=""

DEBUG="false"

LANGCHAIN_TRACING_V2="false"
LANGCHAIN_PROJECT="sre-agent"
LANGCHAIN_API_KEY="YOUR_KEY"