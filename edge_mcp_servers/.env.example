# =============================================================================
# SRE Edge Relay — Customer Configuration
# =============================================================================
# Copy this to .env and fill in your values:  cp .env.example .env

# --- 1. Your Monitoring Stack ---
# Point these at your existing Prometheus and Loki instances
PROMETHEUS_URL=http://host.docker.internal:9090
LOKI_URL=http://host.docker.internal:3100

# --- 2. Your GitHub (for code context & revert PRs) ---
GITHUB_TOKEN=ghp_...
GITHUB_REPO=your-org/your-repo

# --- 3. Local runbooks source of truth ---
# Runbooks live in the repository root `runbooks/` folder and are mounted into the local runbooks MCP server.
